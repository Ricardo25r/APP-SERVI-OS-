# Web de produção do FazTudo: build estático do Next (output:export) servido
# pelo Caddy. O Caddyfile entra por volume no compose (docker-compose.prod.yml).
#
# O `npm run build` roda com NODE_ENV=production → ativa output:export +
# trailingSlash (ver next.config.mjs) e lê `.env.production` (NEXT_PUBLIC_API_URL).
FROM node:20-alpine AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM caddy:2-alpine
COPY --from=build /app/out /srv/web
