# Ambiente de PRODUÇÃO (next build → export e app Capacitor).
# Apenas variáveis NEXT_PUBLIC_* (públicas — viram parte do bundle do cliente).
# O cliente HTTP adiciona "/api/v1" a esta base → https://faztudo.sispeed.com.br/api/v1
NEXT_PUBLIC_API_URL=https://faztudo.sispeed.com.br
NEXT_PUBLIC_PAYMENT_PROVIDER=dev
