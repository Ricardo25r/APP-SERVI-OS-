# Ambiente de PRODUÇÃO (next build → export e app Capacitor).
# Apenas variáveis NEXT_PUBLIC_* (públicas — viram parte do bundle do cliente).
# O cliente HTTP adiciona "/api/v1" a esta base → https://app.inovacomunicacaovisual.com/api/v1
NEXT_PUBLIC_API_URL=https://app.inovacomunicacaovisual.com
NEXT_PUBLIC_PAYMENT_PROVIDER=dev
# Beta: oculta a compra de créditos no app (o backend também recusa).
NEXT_PUBLIC_PAYMENTS_ENABLED=false
