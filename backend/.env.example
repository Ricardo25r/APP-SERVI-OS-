# Variáveis de ambiente do backend FazTudo (contrato Fase 1).
# Copie para `.env` e ajuste conforme necessário.
#
# Dentro do docker-compose, o host de cada serviço é o nome do serviço
# (db, redis, minio). Rodando localmente SEM Docker, troque o host por
# `localhost` (ver comentários ao lado).

# App
APP_ENV=development
APP_DEBUG=true
BACKEND_PORT=8000

# PostgreSQL
POSTGRES_USER=trampoja
POSTGRES_PASSWORD=trampoja_dev
POSTGRES_DB=trampoja
POSTGRES_HOST=db
POSTGRES_PORT=5432
# URL async usada pelo backend (SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://trampoja:trampoja_dev@db:5432/trampoja
# Local (sem Docker):
# DATABASE_URL=postgresql+asyncpg://trampoja:trampoja_dev@localhost:5432/trampoja

# Redis
REDIS_URL=redis://redis:6379/0
# Local (sem Docker):
# REDIS_URL=redis://localhost:6379/0

# Storage (S3 compatível / MinIO em dev)
S3_ENDPOINT=http://minio:9000
# Local (sem Docker):
# S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=trampoja
S3_REGION=us-east-1

# Segurança / JWT
JWT_SECRET=troque-este-segredo-em-producao
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (origens separadas por vírgula)
CORS_ORIGINS=http://localhost:3000

# Pagamentos (Fase 6)
PAYMENT_PROVIDER=dev
PAYMENT_WEBHOOK_SECRET=dev-webhook-secret
PAYMENT_CURRENCY=BRL
PAYMENT_DEV_CHECKOUT_BASE=http://localhost:3000/credits
# Provedores reais (futuro — manter comentado no MVP):
# MP_ACCESS_TOKEN=
# MP_WEBHOOK_SECRET=
# STRIPE_API_KEY=
# STRIPE_WEBHOOK_SECRET=
