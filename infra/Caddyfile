# FazTudo — Caddy INTERNO (atrás do Traefik). Sem TLS: escuta só :80; o Traefik
# da Hostinger termina o HTTPS (Let's Encrypt) e roteia até aqui.
#
# Faz duas coisas no host faztudo.sispeed.com.br:
#   /api/*  → backend FastAPI (mantém o prefixo /api/v1)
#   /*      → SPA estática (Next export): rota → pasta/index.html; fallback /index.html
#
# (As imagens em files.faztudo.sispeed.com.br vão direto do Traefik p/ o MinIO.)
:80 {
	encode gzip zstd

	handle /api/* {
		reverse_proxy backend:8000
	}

	# Mídia pública (avatares, fotos de serviço) servida pelo MinIO no mesmo
	# domínio: /faztudo/<key> == bucket "faztudo" (objetos com leitura anônima).
	handle /faztudo/* {
		reverse_proxy minio:9000
	}

	handle {
		root * /srv/web
		try_files {path} {path}/ /index.html
		file_server
	}
}
