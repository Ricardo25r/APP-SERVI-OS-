# ============================================================================
# FazTudo — .env de PRODUÇÃO. Copie para a RAIZ do projeto como `.env` na VPS:
#   cp infra/env.prod.example .env   (e troque os __TROCAR__)
# Os valores __TROCAR__ devem ser segredos fortes e ÚNICOS (o backend recusa
# subir em produção com os padrões de dev). Nunca comite o `.env` real.
# ============================================================================

# App
APP_ENV=production
APP_DEBUG=false

# PostgreSQL (a senha aqui e na DATABASE_URL têm que ser a MESMA)
POSTGRES_USER=faztudo
POSTGRES_PASSWORD=__TROCAR_SENHA_DB__
POSTGRES_DB=faztudo
DATABASE_URL=postgresql+asyncpg://faztudo:__TROCAR_SENHA_DB__@db:5432/faztudo

# Redis
REDIS_URL=redis://redis:6379/0

# Storage (MinIO interno; imagens públicas via subdomínio files.)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=faztudo
S3_SECRET_KEY=__TROCAR_SENHA_S3__
S3_BUCKET=faztudo
S3_REGION=us-east-1
S3_PUBLIC_URL=https://files.faztudoapp.com.br

# Segurança / JWT (gere com: openssl rand -hex 32)
JWT_SECRET=__TROCAR_64_HEX__

# CORS — domínio web + app nativo (Capacitor)
CORS_ORIGINS=https://faztudoapp.com.br,https://localhost,capacitor://localhost

# Pagamentos — BETA (sem gateway). PAYMENTS_ENABLED=false libera o boot e o
# front esconde a compra; FREE_SIGNUP_CREDITS dá saldo de teste ao profissional.
PAYMENTS_ENABLED=false
PAYMENT_PROVIDER=dev
FREE_SIGNUP_CREDITS=10

# E-mail / alertas — desligados no lançamento (ativar Resend depois)
ALERTS_ENABLED=false

# Links em e-mails / painel
FRONTEND_URL=https://faztudoapp.com.br
MONITORING_URL=https://faztudoapp.com.br/admin/monitoramento

# Obs.: o NEXT_PUBLIC_API_URL do app web é assado no build a partir de
# frontend/.env.production (= https://faztudoapp.com.br) — não precisa aqui.
