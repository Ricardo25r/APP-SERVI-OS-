# FazTudo — variáveis de ambiente (DEV)
# ----------------------------------------------------------------------------
# Copie para `.env` antes de subir o ambiente:
#     cp .env.example .env        (Linux/macOS/Git Bash)
#     copy .env.example .env      (Windows CMD)
#
# O docker-compose e o backend leem deste arquivo. Não comite o `.env` real.
# Os hosts (db, redis, minio) correspondem aos nomes dos serviços no compose.
# Rodando localmente SEM Docker, troque os hosts por `localhost`.
# ----------------------------------------------------------------------------

# App
APP_ENV=development
APP_DEBUG=true
BACKEND_PORT=8000

# PostgreSQL
POSTGRES_USER=faztudo
POSTGRES_PASSWORD=faztudo_dev
POSTGRES_DB=faztudo
POSTGRES_HOST=db
POSTGRES_PORT=5432
# URL async usada pelo backend (SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://faztudo:faztudo_dev@db:5432/faztudo

# Redis
REDIS_URL=redis://redis:6379/0

# Storage (S3 compatível / MinIO em dev)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=faztudo
S3_REGION=us-east-1

# Segurança / JWT
JWT_SECRET=troque-este-segredo-em-producao
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000

# Pagamentos (Fase 6)
PAYMENT_PROVIDER=dev
PAYMENT_WEBHOOK_SECRET=dev-webhook-secret
PAYMENT_CURRENCY=BRL
PAYMENT_DEV_CHECKOUT_BASE=http://localhost:3000/credits
# Provedores reais (futuro — manter comentado no MVP):
# MP_ACCESS_TOKEN=
# MP_WEBHOOK_SECRET=
# STRIPE_API_KEY=
# STRIPE_WEBHOOK_SECRET=

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
# Espelha o backend; só controla a exibição do botão de confirmação simulada.
NEXT_PUBLIC_PAYMENT_PROVIDER=dev

# Storage público (URLs presignadas / avatares) — host acessível pelo NAVEGADOR
S3_PUBLIC_URL=http://localhost:9000

# E-mail / SMTP (alertas de monitoramento, reset de senha, chamados de suporte)
ALERTS_ENABLED=false
ALERT_EMAIL_TO=
ALERT_SLOW_MS=3000
ALERT_COOLDOWN_SECONDS=300
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_STARTTLS=true
# Dev (Mailpit):  SMTP_HOST=mailpit SMTP_PORT=1025 SMTP_STARTTLS=false
# Resend:         SMTP_HOST=smtp.resend.com SMTP_PORT=465 SMTP_USER=resend
#                 SMTP_PASSWORD=re_xxx  SMTP_FROM="FazTudo <nao-responda@seudominio.com.br>"

# URLs públicas usadas em links de e-mail
FRONTEND_URL=http://localhost:3000
MONITORING_URL=http://localhost:3000/admin/monitoramento

# ----------------------------------------------------------------------------
# PRODUÇÃO (APP_ENV=production) — o backend RECUSA subir com valores inseguros:
#   - JWT_SECRET / PAYMENT_WEBHOOK_SECRET fortes (não os defaults)
#   - PAYMENT_PROVIDER != dev (gateway real) e APP_DEBUG=false
#   - CORS_ORIGINS = domínio(s) exato(s) do app (ex.: https://app.faztudo.com.br)
#   - DATABASE_URL/REDIS_URL/S3_* apontando para serviços gerenciados
#   - SMTP real (Resend) + ALERTS_ENABLED=true + ALERT_EMAIL_TO
#   Ver docs/DEPLOY.md.
# ----------------------------------------------------------------------------
